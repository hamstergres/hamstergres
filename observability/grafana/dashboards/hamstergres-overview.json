    {"type":"timeseries","title":"PostgreSQL connections","id":10,"gridPos":{"x":12,"y":20,"w":12,"h":8},"targets":[{"expr":"pg_stat_database_numbackends{datname=\"hamstergres\"}","legendFormat":"{{burrow}}"}]},
    {"type":"timeseries","title":"PostgreSQL transactions","id":11,"gridPos":{"x":0,"y":28,"w":12,"h":8},"targets":[{"expr":"rate(pg_stat_database_xact_commit{datname=\"hamstergres\"}[5m])","legendFormat":"{{burrow}} commits"},{"expr":"rate(pg_stat_database_xact_rollback{datname=\"hamstergres\"}[5m])","legendFormat":"{{burrow}} rollbacks"}]},
    {"type":"timeseries","title":"Database size","id":12,"gridPos":{"x":12,"y":28,"w":12,"h":8},"targets":[{"expr":"pg_database_size_bytes{datname=\"hamstergres\"}","legendFormat":"{{burrow}}"}],"fieldConfig":{"defaults":{"unit":"bytes"},"overrides":[]}},
    {"type":"timeseries","title":"Checkpoints and WAL","id":13,"gridPos":{"x":0,"y":36,"w":12,"h":8},"targets":[{"expr":"rate(pg_stat_checkpointer_num_timed[5m])","legendFormat":"{{burrow}} timed checkpoints"},{"expr":"rate(pg_stat_checkpointer_num_requested[5m])","legendFormat":"{{burrow}} requested checkpoints"},{"expr":"pg_wal_size_bytes","legendFormat":"{{burrow}} WAL size"}],"fieldConfig":{"defaults":{},"overrides":[{"matcher":{"id":"byName","options":"WAL size"},"properties":[{"id":"unit","value":"bytes"}]}]}},
    {"type":"timeseries","title":"Locks and prepared transactions","id":14,"gridPos":{"x":12,"y":36,"w":12,"h":8},"targets":[{"expr":"pg_locks_count{datname=\"hamstergres\"}","legendFormat":"{{burrow}} {{mode}}"},{"expr":"pg_prepared_transactions_count","legendFormat":"{{burrow}} prepared"}]},
    {"type":"timeseries","title":"Nest apply latency","id":15,"gridPos":{"x":0,"y":44,"w":12,"h":8},"targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(etcd_server_apply_duration_seconds_bucket[5m])))","legendFormat":"p95"}],"fieldConfig":{"defaults":{"unit":"s"},"overrides":[]}},
