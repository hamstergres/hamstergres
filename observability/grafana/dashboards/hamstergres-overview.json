    {"type":"timeseries","title":"Proxy traffic and errors","id":4,"gridPos":{"x":0,"y":4,"w":12,"h":8},"targets":[{"expr":"sum by (outcome) (rate(hamstergres_proxy_queries_total[1m]))","legendFormat":"{{outcome}}"}]},
    {"type":"timeseries","title":"Query latency percentiles","id":5,"gridPos":{"x":12,"y":4,"w":12,"h":8},"targets":[{"expr":"histogram_quantile(0.50, sum by (le) (rate(hamstergres_proxy_query_duration_seconds_bucket[5m])))","legendFormat":"p50"},{"expr":"histogram_quantile(0.95, sum by (le) (rate(hamstergres_proxy_query_duration_seconds_bucket[5m])))","legendFormat":"p95"},{"expr":"histogram_quantile(0.99, sum by (le) (rate(hamstergres_proxy_query_duration_seconds_bucket[5m])))","legendFormat":"p99"}],"fieldConfig":{"defaults":{"unit":"s"},"overrides":[]}},
    {"type":"timeseries","title":"Routing decisions","id":6,"gridPos":{"x":0,"y":12,"w":8,"h":8},"targets":[{"expr":"sum by (route) (rate(hamstergres_proxy_query_routes_total[1m]))","legendFormat":"{{route}}"}]},
    {"type":"timeseries","title":"Executions by Burrow","id":7,"gridPos":{"x":8,"y":12,"w":8,"h":8},"targets":[{"expr":"sum by (burrow) (rate(hamstergres_proxy_burrow_executions_total[1m]))","legendFormat":"{{burrow}}"}]},
    {"type":"timeseries","title":"Frontend sessions","id":8,"gridPos":{"x":16,"y":12,"w":8,"h":8},"targets":[{"expr":"hamstergres_proxy_frontend_connections","legendFormat":"{{state}}"}]},
